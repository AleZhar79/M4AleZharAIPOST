# Блок 1: база данных
DATABASE_URL=sqlite:///./aibot.db

# Блок 3: очередь задач
REDIS_URL=redis://localhost:6379/0

# Блок 4: AI через OpenRouter (https://openrouter.ai/keys)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemma-4-31b-it:free

# Блок 5: Telegram (Telethon, user-account)
# API_ID / API_HASH: либо свои с https://my.telegram.org/apps,
# либо публичные тестовые ID=6 / HASH=eb06d4abfb49dc3eeb1aeb98ae0f581e
# (только для учебного проекта, не для прода).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                # +7XXXXXXXXXX, тот же номер, под которым ты в Telegram
TELEGRAM_CHANNEL=              # @username твоего канала, где ты админ
TELEGRAM_SESSION_NAME=tg_session
